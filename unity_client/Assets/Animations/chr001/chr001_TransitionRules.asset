%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: c91c4673c7fb7dc499add67759ab9924, type: 3}
  m_Name: chr001_TransitionRules
  m_EditorClassIdentifier: CyanNook::CyanNook.Character.TransitionRuleData
  description: "chr001 \u306E\u30A2\u30CB\u30E1\u30FC\u30B7\u30E7\u30F3\u9077\u79FB\u30EB\u30FC\u30EB\u4E00\u89A7\u3002Editor\u30A6\u30A3\u30F3\u30C9\u30A6\uFF08CyanNook
    > Animation > Transition Viewer\uFF09\u3067\u95B2\u89A7\u7528\u3002\u30E9\u30F3\u30BF\u30A4\u30E0\u6319\u52D5\u306B\u306F\u5F71\u97FF\u3057\u306A\u3044\uFF08\u95B2\u89A7\u5C02\u7528\uFF09\u3002"
  rules:
  - category: Common
    fromState: 0
    fromAnimationId: 
    toState: 1
    toAnimationId: 
    orchestrator: TalkController / ChatManager
    trigger: "LLM action=move / \u30E6\u30FC\u30B6\u30FC\u79FB\u52D5\u8981\u6C42"
    notes: "CharacterController \u304C action=move \u3092\u53D7\u3051\u3001CharacterNavigationController
      \u7D4C\u7531\u3067 Walk \u958B\u59CB"
  - category: Common
    fromState: 1
    fromAnimationId: 
    toState: 0
    toAnimationId: 
    orchestrator: CharacterNavigationController
    trigger: "\u76EE\u7684\u5730\u5230\u9054 / \u79FB\u52D5\u30AD\u30E3\u30F3\u30BB\u30EB"
    notes: "NavMeshAgent \u306E\u505C\u6B62\u3092\u691C\u77E5\u3057\u3066 ReturnToIdle"
  - category: Common
    fromState: 0
    fromAnimationId: 
    toState: 3
    toAnimationId: talk_idle01
    orchestrator: TalkController.EnterTalk
    trigger: "\u4F1A\u8A71\u958B\u59CB\uFF08\u79FB\u52D5\u2192\u5BFE\u9762\u5F8C\uFF09"
    notes: "EnterTalk \u5185\u3067 PlayState(Talk, \"talk_idle01\")"
  - category: Talk
    fromState: 3
    fromAnimationId: talk_idle01
    toState: 4
    toAnimationId: emote_happy01
    orchestrator: ChatManager
    trigger: "LLM\u30EC\u30B9\u30DD\u30F3\u30B9\u3067 emote \u30D5\u30A3\u30FC\u30EB\u30C9\u53D7\u4FE1"
    notes: "CharacterController.ProcessEmoteFromField \u2192 PlayEmoteWithReturn"
  - category: Talk
    fromState: 4
    fromAnimationId: 
    toState: 3
    toAnimationId: talk_idle01
    orchestrator: PlayEmoteWithReturn
    trigger: "emote_ed \u5B8C\u4E86 or emoteHoldDuration \u7D4C\u904E"
    notes: "CharacterAnimationController \u5185\u3067 _emoteReturnState \u306BTalk\u304C\u5165\u3063\u3066\u3044\u308B\u5834\u5408"
  - category: Talk
    fromState: 3
    fromAnimationId: talk_idle01
    toState: 6
    toAnimationId: talk_thinking01
    orchestrator: ChatManager / CharacterController
    trigger: "LLM\u30B9\u30C8\u30EA\u30FC\u30E0\u9045\u5EF6\u3067 think \u518D\u751F"
    notes: "\u52A0\u7B97(Additive)\u3067\u518D\u751F\u3055\u308C\u308B\u5834\u5408\u3082\u3042\u308B\uFF08sit\u4E2D\u306A\u3069\uFF09"
  - category: Talk
    fromState: 6
    fromAnimationId: talk_thinking01
    toState: 3
    toAnimationId: talk_idle01
    orchestrator: StopThinkingAndReturn
    trigger: "LLM\u30EC\u30B9\u30DD\u30F3\u30B9\u5230\u9054"
    notes: "think_ed \u5B8C\u4E86\u5F8C\u306B\u5143\u306E\u72B6\u614B\u3078\u5FA9\u5E30"
  - category: Talk
    fromState: 3
    fromAnimationId: talk_idle01
    toState: 0
    toAnimationId: 
    orchestrator: TalkController.ExitTalk
    trigger: "\u4F1A\u8A71\u7D42\u4E86 / \u30BF\u30A4\u30E0\u30A2\u30A6\u30C8"
    notes: "talk_idle_ed \u2192 Idle"
  - category: Interact
    fromState: 0
    fromAnimationId: 
    toState: 5
    toAnimationId: interact_entry01
    orchestrator: InteractionController.StartInteraction
    trigger: "LLM action=interact_sit/sleep \u7B49"
    notes: "\u307E\u305A NavMesh \u3067\u5BB6\u5177\u4F4D\u7F6E\u307E\u3067\u79FB\u52D5\u3001\u305D\u306E\u5F8C
      entry \u30D5\u30A7\u30FC\u30BA"
  - category: Interact
    fromState: 5
    fromAnimationId: interact_entry01
    toState: 5
    toAnimationId: interact_sit01
    orchestrator: Timeline signal / LoopRegion
    trigger: "entry \u30E2\u30FC\u30B7\u30E7\u30F3\u5B8C\u4E86"
    notes: "LoopRegionTrack \u306B\u3088\u308A\u30EB\u30FC\u30D7\u533A\u9593\u306B\u9077\u79FB"
  - category: Interact
    fromState: 5
    fromAnimationId: interact_sit01
    toState: 4
    toAnimationId: emote_happy01
    orchestrator: ChatManager (additive)
    trigger: "sit \u30EB\u30FC\u30D7\u4E2D\u306B emote \u53D7\u4FE1"
    notes: "\u52A0\u7B97\u3067\u4E0A\u534A\u8EAB\u306E\u307F\u518D\u751F\u3002EmotePlayableTrack
      \u3068 AdditiveCancelTrack \u3067\u5236\u5FA1"
  - category: Interact
    fromState: 5
    fromAnimationId: interact_sit01
    toState: 5
    toAnimationId: interact_exit01
    orchestrator: InteractionController.ExitLoop
    trigger: "\u9000\u51FA\u8981\u6C42\uFF08\u6B21\u30A2\u30AF\u30B7\u30E7\u30F3\u304C\u6765\u305F\u7B49\uFF09"
    notes: "LoopRegion \u3092\u629C\u3051\u3066 ed \u30D5\u30A7\u30FC\u30BA\u3078"
  - category: Interact
    fromState: 5
    fromAnimationId: interact_exit01
    toState: 0
    toAnimationId: 
    orchestrator: OnInteractionComplete
    trigger: "exit \u30E2\u30FC\u30B7\u30E7\u30F3\u5B8C\u4E86"
    notes: "CharacterAnimationController \u304B\u3089\u30A4\u30D9\u30F3\u30C8\u767A\u706B
      \u2192 Idle \u5FA9\u5E30"
  - category: Sleep
    fromState: 0
    fromAnimationId: 
    toState: 5
    toAnimationId: interact_sleep01
    orchestrator: SleepController.StartSleep
    trigger: LLM action=interact_sleep
    notes: "entry \u2192 sleep_loop\u3002Boredom / \u5922\u30BF\u30A4\u30DE\u30FC\u304C\u52D5\u304D\u59CB\u3081\u308B"
  - category: Sleep
    fromState: 5
    fromAnimationId: interact_sleep01
    toState: 4
    toAnimationId: emote_relaxed01
    orchestrator: SleepController dream
    trigger: "\u5922\u30BF\u30A4\u30DE\u30FC\u767A\u706B"
    notes: "\u52A0\u7B97\u3067\u8868\u60C5\u30FB\u8EAB\u3058\u308D\u304E\u3092\u518D\u751F"
  - category: Sleep
    fromState: 5
    fromAnimationId: interact_sleep01
    toState: 0
    toAnimationId: 
    orchestrator: SleepController.ExitSleep
    trigger: "\u8D77\u5E8A\uFF08\u30BF\u30A4\u30DE\u30FC\u6E80\u4E86 / \u30E6\u30FC\u30B6\u30FC\u64CD\u4F5C\uFF09"
    notes: "sleep_exit \u2192 Idle"
  - category: Boredom
    fromState: 0
    fromAnimationId: common_idle01_lp
    toState: 0
    toAnimationId: common_idle02_lp
    orchestrator: BoredomController
    trigger: "\u9000\u5C48\u30BF\u30A4\u30DE\u30FC\u6E80\u4E86\uFF08idle \u5DE1\u56DE\uFF09"
    notes: "idle01/02/03 \u3092\u30E9\u30F3\u30C0\u30E0 or \u9806\u6B21\u3067\u5207\u308A\u66FF\u3048\u308B"
